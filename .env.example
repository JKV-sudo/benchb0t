# ─────────────────────────────────────────────────────────────────────────────
# benchb0t — environment variable template
# Copy to .env and fill in your values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Default endpoint (used when harness does not specify one) ─────────────────
BENCHBOT_BASE_URL=http://localhost:11434/v1   # Ollama, vLLM, OpenRouter, OpenAI…
BENCHBOT_API_KEY=ollama                       # set to your actual key for cloud endpoints

# ── Harness-specific overrides (optional) ────────────────────────────────────
# SLAVKO_BASE_URL=http://localhost:11434/v1
# SLAVKO_API_KEY=ollama

# HERMES_BASE_URL=https://openrouter.ai/api/v1
# HERMES_API_KEY=sk-or-...

# OC_NANO_BASE_URL=http://localhost:8000/v1
# OC_NANO_API_KEY=none

# ── Docker ───────────────────────────────────────────────────────────────────
# DOCKER_HOST=unix:///var/run/docker.sock    # override if using a remote daemon

# ── Optional: LLM judge endpoint (used by evaluation type: llm_judge) ────────
# JUDGE_BASE_URL=https://api.openai.com/v1
# JUDGE_API_KEY=sk-...
# JUDGE_MODEL=gpt-4o
